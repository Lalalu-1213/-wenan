# 大模型API配置（OpenAI风格）
# 如使用OpenAI官方API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-3.5-turbo

# 如使用国内中转API（示例）
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.your-provider.com
# OPENAI_MODEL=gpt-3.5-turbo

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
